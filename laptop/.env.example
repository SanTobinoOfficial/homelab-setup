# ── Nextcloud / DB ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
DB_ROOT_PASSWORD=CHANGE_ME_32_CHARS
DB_PASSWORD=CHANGE_ME_32_CHARS
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Node Agent ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
AGENT_API_KEY=CHANGE_ME_64_CHARS

# ── Pi-hole ───────────────────────────────────────────────────
PIHOLE_PASSWORD=CHANGE_ME_PIHOLE_PASSWORD

# ── User Portal / Heimdall ────────────────────────────────────
# IP laptopa (do linków w Heimdall)
LAPTOP_IP=192.168.1.100

# ── Discord Bot ───────────────────────────────────────────────
# Token bota z Discord Developer Portal → discordapp.com/developers/applications
DISCORD_TOKEN=TWOJ_TOKEN_DISCORD_BOTA

# ID kanału Discord (prawy klik na kanał → Kopiuj ID, wymaga Developer Mode)
ALLOWED_CHANNEL_ID=ID_KANALU_DISCORD

# Twoje ID na Discordzie (prawy klik na siebie → Kopiuj ID)
ADMIN_USER_ID=TWOJE_DISCORD_USER_ID

# Webhook do powiadomień o nowych urządzeniach (opcjonalne)
DISCORD_WEBHOOK_URL=
