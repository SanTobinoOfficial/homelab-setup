# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Discord Channel ID where bot listens (right-click channel → Copy ID)
ALLOWED_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# Discord User ID who can use admin commands (right-click your profile → Copy ID)
ADMIN_USER_ID=YOUR_DISCORD_USER_ID_HERE

# Node Agent API (running on this laptop)
AGENT_URL=http://localhost:9090
AGENT_API_KEY=PASTE_AGENT_API_KEY_FROM_OPT_HOMELAB_ENV

# Claude Code CLI path (usually just "claude" if in PATH)
CLAUDE_CLI=claude

# Max seconds to wait for Claude response
CLAUDE_TIMEOUT=120

# Minutes of inactivity before a Claude thread session expires (default: 30)
CLAUDE_SESSION_TIMEOUT=30
