# IP address of your Laptop (server node)
LAPTOP_IP=192.168.1.100

# Node Agent API key (from laptop's /opt/homelab/.env AGENT_API_KEY)
AGENT_API_KEY=PASTE_YOUR_AGENT_API_KEY_HERE

# SSH credentials for laptop (optional, for log access)
SSH_USER=your_laptop_username
SSH_KEY_PATH=C:/Users/Tobiasz/.ssh/homelabkey

# Dashboard port
PORT=3000
